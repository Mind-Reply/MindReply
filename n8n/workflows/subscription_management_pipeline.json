{
  "name": "MindReply - Subscription Management Pipeline",
  "description": "Automated subscription lifecycle - upgrades, downgrades, cancellations, renewals",
  "active": true,
  "nodes": [
    {"id": "start", "type": "n8n-nodes-base.start", "position": [50, 50], "typeVersion": 1},
    {"id": "sub_webhook", "type": "n8n-nodes-base.webhook", "position": [250, 50], "typeVersion": 1, "parameters": {"httpMethod": "POST", "path": "subscription-change"}},
    {"id": "update_subscription", "type": "n8n-nodes-base.postgres", "position": [450, 50], "typeVersion": 1, "parameters": {"host": "={{$env.DB_HOST}}", "port": 5432, "database": "={{$env.DB_NAME}}", "user": "={{$env.DB_USER}}", "password": "={{$env.DB_PASSWORD}}", "query": "UPDATE subscriptions SET plan = '={{$json.new_plan}}', updated_at = NOW() WHERE user_id = '={{$json.user_id}}'"}},
    {"id": "process_payment", "type": "n8n-nodes-base.httpRequest", "position": [650, 50], "typeVersion": 1, "parameters": {"url": "https://api.stripe.com/v1/subscriptions", "requestMethod": "POST", "body": {"customer": "={{$json.stripe_customer}}", "items": [{"price": "={{$json.stripe_price_id}}"}]}}},
    {"id": "send_confirmation", "type": "n8n-nodes-base.emailSend", "position": [850, 50], "typeVersion": 1, "parameters": {"toEmail": "={{$json.customer_email}}", "subject": "Subscription Updated", "text": "Your subscription has been updated to {{$json.new_plan}}. New amount: ${{$json.new_price}}/month"}}
  ],
  "connections": {"start": {"main": [[{"node": "sub_webhook", "type": "main", "index": 0}]]}, "sub_webhook": {"main": [[{"node": "update_subscription", "type": "main", "index": 0}]]}, "update_subscription": {"main": [[{"node": "process_payment", "type": "main", "index": 0}]]}, "process_payment": {"main": [[{"node": "send_confirmation", "type": "main", "index": 0}]]}}
}
