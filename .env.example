# Required for Drizzle/PostgreSQL-backed API routes.
DATABASE_URL="postgres://user:password@host:5432/mindreply"

# Public canonical site URL used by Next.js metadata.
NEXT_PUBLIC_SITE_URL="https://mind-reply.com"

# Optional app secrets. Keep real values in local/Vercel/GitHub secrets only.
JWT_SECRET="replace-with-a-long-random-secret"
SENTRY_DSN=""
