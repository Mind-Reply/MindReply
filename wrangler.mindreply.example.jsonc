{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mindreply-memory-edge",
  "main": "src/edge/cloudflare/memory_durable_object.ts",
  "compatibility_date": "2026-06-10",
  "durable_objects": {
    "bindings": [
      {
        "name": "WORKSPACE_MEMORY",
        "class_name": "WorkspaceMemory"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WorkspaceMemory"]
    }
  ]
}
