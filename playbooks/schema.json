{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MindReply Playbook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "playbook_id",
    "title",
    "description",
    "version",
    "triggers",
    "decision_tree",
    "actions",
    "verification",
    "audit"
  ],
  "properties": {
    "playbook_id": { "type": "string", "minLength": 3 },
    "title": { "type": "string", "minLength": 3 },
    "description": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "minLength": 1 },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern"],
        "properties": {
          "pattern": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decision_tree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "action", "synthesis"],
            "properties": {
              "id": { "type": "string" },
              "action": { "type": "string", "enum": ["reply", "schedule", "resolve", "escalate"] },
              "synthesis": { "type": "string" }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": { "type": "string", "enum": ["reply", "schedule", "resolve", "escalate"] }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signed", "redaction_level"],
      "properties": {
        "signed": { "type": "boolean" },
        "redaction_level": { "type": "string" }
      }
    }
  }
}
