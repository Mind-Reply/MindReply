{
  "playbook_id": "compliance-audit-trail",
  "title": "Compliance audit trail",
  "description": "Captures sensitive compliance items as signed receipts.",
  "version": "1.0",
  "triggers": [{ "type": "email", "pattern": "audit" }, { "type": "manual", "pattern": "policy" }, { "type": "webhook", "pattern": "breach" }],
